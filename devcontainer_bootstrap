#!/usr/bin/env bash
set -euo pipefail

echo "[devcontainer] Running bootstrap..."

mkdir -p /mnt/supervisor/homeassistant/custom_components

if [[ -n "${WORKSPACE_DIRECTORY:-}" && -d "${WORKSPACE_DIRECTORY}" ]]; then
  git config --global --add safe.directory "${WORKSPACE_DIRECTORY}" || true
fi

# The devcontainer image defaults Docker logging to journald, which can fail
# when journald is unavailable in containerized runtimes.
if [[ -d /etc/docker && -w /etc/docker ]] || [[ ! -e /etc/docker && -w /etc ]]; then
  mkdir -p /etc/docker
  printf '%s\n' '{"log-driver": "json-file"}' > /etc/docker/daemon.json
else
  echo "[devcontainer] Skipping Docker daemon config; /etc/docker is not writable."
fi

# Patch stty sane in supervisor common scripts so startup doesn't fail when
# there is no TTY (e.g. VS Code task terminal).
if [[ -f /etc/supervisor_scripts/common ]] && grep -q '^\s*stty sane\s*$' /etc/supervisor_scripts/common; then
  sed -i 's/^\(    stty sane\)$/\1 2>\/dev\/null || true/' /etc/supervisor_scripts/common
  echo "[devcontainer] Patched stty sane in /etc/supervisor_scripts/common."
fi

if supervisor_bootstrap_path="$(command -v supervisor_bootstrap 2>/dev/null)" && [[ -x "${supervisor_bootstrap_path}" ]]; then
  echo "[devcontainer] Running supervisor_bootstrap..."
  supervisor_bootstrap
else
  echo "[devcontainer] supervisor_bootstrap not runnable, skipping."
fi

if command -v supervisor_run >/dev/null 2>&1; then
  echo "[devcontainer] supervisor_run is available. Use the 'Start Home Assistant' task to launch it."
else
  echo "[devcontainer] supervisor_run not found."
fi

if [[ -d /mnt/supervisor/homeassistant/custom_components/grid_coordinator ]]; then
  echo "[devcontainer] Custom integration is mounted in supervisor Home Assistant config."
else
  echo "[devcontainer] WARNING: grid_coordinator not mounted under /mnt/supervisor/homeassistant/custom_components"
fi

# Suppress noisy OS-agent socket debug messages (expected in devcontainers).
# Only works if the supervisor is already running (e.g. on container reconnect).
if command -v ha >/dev/null 2>&1 && ha supervisor info >/dev/null 2>&1; then
  echo "[devcontainer] Setting supervisor logging to info with debug disabled..."
  ha supervisor options --logging info --debug=false || true
else
  echo "[devcontainer] Supervisor not running yet; the 'Start Home Assistant' task will set supervisor logging after startup."
fi

echo "[devcontainer] Bootstrap complete."
